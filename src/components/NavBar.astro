---
import { eventMeta, navLinks } from '../data/site';
---

<header
  data-site-header
  class="fixed inset-x-0 top-0 z-50 border-b border-white/40 bg-white/65 backdrop-blur-xl"
>
  <div class="shell flex items-center justify-between gap-4 py-4">
    <a href="#evento" class="flex items-center gap-3">
      <span class="flex h-11 w-11 items-center justify-center overflow-hidden rounded-full bg-white ring-1 ring-rose/10">
        <img
          src="/fotos/logo-PeA-fundo-branco.webp"
          alt="Logo do Pessoas em Ação"
          class="h-full w-full scale-[1.19] object-cover"
        />
      </span>
      <span class="font-display text-lg font-extrabold tracking-[-0.04em] text-ink sm:text-xl">
        {eventMeta.name}
      </span>
    </a>

    <nav class="hidden items-center gap-7 lg:flex">
      {navLinks.map((item) => (
        <a
          href={item.href}
          class="text-sm font-bold uppercase tracking-[0.18em] text-ink-soft hover:text-rose"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href={eventMeta.whatsappTicketUrl}
      target="_blank"
      rel="noreferrer"
      class="cta-primary cta-primary--slim shrink-0 whitespace-nowrap"
    >
      Garantir vaga
    </a>
  </div>
</header>
