---
import { pillars } from '../../data/site';
---

<section class="section-space relative" id="essencia">
  <div class="shell">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,0.95fr)_minmax(320px,1.05fr)] lg:items-end">
      <div data-reveal class="reveal-ready space-y-5">
        <span class="eyebrow">O que e o Pessoas em Acao</span>
        <h2 class="section-heading max-w-xl">
          Nao e so um evento. E o tipo de ambiente que muda o seu ritmo.
        </h2>
      </div>
      <p data-reveal style="--delay: 120ms" class="reveal-ready section-copy max-w-2xl">
        Pessoas certas se encontram no lugar certo para transformar conversa em oportunidade,
        aprendizado em pratica e presenca em memoria. O evento foi desenhado para parecer leve,
        mas entregar mais do que se espera.
      </p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {pillars.map((pillar, index) => (
        <article
          data-reveal
          style={`--delay:${index * 90 + 120}ms`}
          class="reveal-ready surface-card relative overflow-hidden p-8 sm:p-9"
        >
          <div
            class={`absolute -right-10 -top-10 h-32 w-32 rounded-full ${
              pillar.accent === 'rose'
                ? 'bg-rose-soft/18'
                : pillar.accent === 'sky'
                  ? 'bg-sky-soft/18'
                  : 'bg-ink/8'
            }`}
          ></div>

          <div
            class={`inline-flex h-12 w-12 items-center justify-center rounded-2xl text-xl font-black ${
              pillar.accent === 'rose'
                ? 'bg-rose text-white'
                : pillar.accent === 'sky'
                  ? 'bg-sky text-white'
                  : 'bg-ink text-white'
            }`}
          >
            {index + 1}
          </div>
          <h3 class="mt-6 text-3xl font-bold tracking-[-0.04em] text-ink">{pillar.title}</h3>
          <p class="mt-5 text-base leading-8 text-ink-soft">{pillar.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
