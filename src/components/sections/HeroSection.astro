---
import { eventMeta, heroHighlights, heroRibbon, heroStats } from '../../data/site';
---

<section id="evento" class="section-space relative overflow-hidden pt-32 sm:pt-36">
  <div class="orb -left-14 top-20 h-40 w-40 bg-rose-soft/25 animate-float"></div>
  <div class="orb right-0 top-0 h-56 w-56 bg-sky-soft/25 animate-float-slow"></div>

  <div class="shell">
    <div class="grid items-center gap-12 lg:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)]">
      <div class="min-w-0 space-y-8">
        <div data-reveal style="--delay: 80ms" class="reveal-ready space-y-5">
          <span class="eyebrow">{eventMeta.editionLabel}</span>
          <h1 class="section-heading max-w-4xl">
            Ainda esperando o <span class="text-rose italic">momento certo</span> para crescer?
            Ele é agora.
          </h1>
          <p class="section-copy max-w-2xl text-lg sm:text-xl">
            Networking, conhecimento e entretenimento num só lugar. Para quem quer sair do
            modo passivo e entrar em movimento.
          </p>
        </div>

        <div data-reveal style="--delay: 160ms" class="reveal-ready flex flex-wrap gap-3">
          <span class="section-tag">{eventMeta.dateDisplay}</span>
          <span class="section-tag">{eventMeta.city}</span>
          <span class="section-tag">{eventMeta.capacity}</span>
        </div>

        <div data-reveal style="--delay: 220ms" class="reveal-ready flex flex-col gap-4 sm:flex-row">
          <a
            href={eventMeta.whatsappTicketUrl}
            target="_blank"
            rel="noreferrer"
            class="cta-primary breathe"
          >
            Garantir minha vaga
          </a>
          <a
            href={eventMeta.whatsappSupportUrl}
            target="_blank"
            rel="noreferrer"
            class="cta-secondary"
          >
            Falar no WhatsApp
          </a>
        </div>

        <div
          data-reveal
          style="--delay: 300ms"
          class="reveal-ready grid gap-4 sm:grid-cols-2 xl:grid-cols-4"
        >
          {heroStats.map((item, index) => (
            <article
              class="surface-card hover-lift relative overflow-hidden px-5 py-5"
              style={`--delay:${index * 80}ms`}
            >
              <div class="absolute right-0 top-0 h-24 w-24 -translate-y-10 translate-x-10 rounded-full bg-gradient-to-br from-rose-soft/20 to-sky-soft/20"></div>
              <div class="text-lg font-extrabold uppercase tracking-[0.16em] text-rose">{item.value}</div>
              <p class="mt-2 max-w-[14rem] text-sm font-medium leading-6 text-ink-soft">
                {item.label}
              </p>
            </article>
          ))}
        </div>
      </div>

      <div data-reveal style="--delay: 180ms" class="reveal-ready min-w-0">
        <div class="relative min-w-0" data-pointer-parallax>
          <div class="absolute -left-8 top-8 hidden rounded-full bg-white/80 px-4 py-3 text-xs font-bold uppercase tracking-[0.2em] text-ink-soft shadow-soft lg:block">
            Energia real
          </div>
          <div class="surface-card relative overflow-hidden rounded-[2.3rem] bg-hero-aura p-4 sm:p-5">
            <div class="relative overflow-hidden rounded-[1.9rem]">
              <img
                src="/fotos/foto-hero.webp"
                alt="Grupo de pessoas em um ambiente de evento, sorrindo e conversando."
                class="aspect-[4/4.7] w-full rounded-[1.7rem] object-cover animate-float-slow sm:aspect-[4/4.4]"
              />
            </div>

            <div class="mt-5 grid gap-4 lg:grid-cols-[auto_1fr]">
              <div class="rounded-[1.5rem] bg-ink px-5 py-5 text-white shadow-soft">
                <div class="text-[0.72rem] font-bold uppercase tracking-[0.28em] text-white/60">
                  Ingresso
                </div>
                <div class="mt-1 font-display text-4xl font-extrabold">{eventMeta.price}</div>
                <p class="mt-2 text-sm text-white/72">Lote único com vagas limitadas.</p>
              </div>

              <div class="rounded-[1.6rem] bg-white/88 p-5 backdrop-blur-xl">
                <p class="text-[0.72rem] font-extrabold uppercase tracking-[0.28em] text-rose">
                  O que você vai viver
                </p>
                <div class="mt-4 flex flex-wrap gap-3 text-sm font-semibold text-ink">
                  {heroHighlights.map((item) => (
                    <span class="rounded-full bg-surface px-4 py-2.5 shadow-[inset_0_0_0_1px_rgba(205,199,206,0.55)]">
                      {item}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>

        <div
          data-reveal
          style="--delay: 360ms"
          class="reveal-ready mt-6 glass-panel max-w-full overflow-hidden py-4 sm:mt-8"
        >
          <div class="w-full overflow-hidden">
            <div class="flex w-fit min-w-max items-center gap-3 animate-marquee pr-3">
              {[...heroRibbon, ...heroRibbon].map((item, index) => (
                <span class="flex items-center gap-3" aria-hidden={index >= heroRibbon.length}>
                  <span class="rounded-full bg-ink px-3 py-2 text-[0.68rem] font-extrabold uppercase tracking-[0.22em] text-white">
                    {item}
                  </span>
                  <span class="h-2.5 w-2.5 rounded-full bg-gradient-to-r from-rose to-sky"></span>
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
