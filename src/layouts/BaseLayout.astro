---
import NavBar from '../components/NavBar.astro';
import LiaFloat from '../components/LiaFloat.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Pessoas em Ação - 6ª edição oficial',
  description = 'Landing page oficial do evento Pessoas em Ação: networking, conhecimento e entretenimento em Cabo Frio.',
} = Astro.props;

const siteUrl = 'https://pessoas-em-acao.vercel.app';
const ogImage = `${siteUrl}/fotos/og-pea.png`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f0eff2" />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" type="image/webp" href="/fotos/logo-PeA-fundo-branco.webp" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="Pessoas em Ação" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <a
      href="#conteudo"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[60] focus:rounded-full focus:bg-white focus:px-5 focus:py-3 focus:font-bold focus:text-ink"
    >
      Ir para o conteúdo
    </a>
    <NavBar />
    <main id="conteudo">
      <slot />
    </main>
    <LiaFloat />

    <script is:inline>
      const initializeMotion = () => {
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const reveals = [...document.querySelectorAll('[data-reveal]')];

        if (reduceMotion) {
          document.documentElement.dataset.motionMode = 'reduced';
          reveals.forEach((element) => element.classList.add('is-visible'));
        } else {
          document.documentElement.dataset.motionMode = 'full';
          document.documentElement.classList.add('motion-enabled');

          window.requestAnimationFrame(() => {
            window.requestAnimationFrame(() => {
              const viewportTrigger = window.innerHeight * 0.92;
              const visibleQueue = [];

              reveals.forEach((element) => {
                const box = element.getBoundingClientRect();
                if (box.top <= viewportTrigger) {
                  visibleQueue.push(element);
                }
              });

              visibleQueue.forEach((element, index) => {
                window.setTimeout(() => {
                  element.classList.add('is-visible');
                }, 160 + index * 130);
              });

              const observer = new IntersectionObserver(
                (entries) => {
                  entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                      entry.target.classList.add('is-visible');
                      observer.unobserve(entry.target);
                    }
                  });
                },
                { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
              );

              reveals.forEach((element) => {
                if (!visibleQueue.includes(element)) {
                  observer.observe(element);
                }
              });
            });
          });

          const parallaxTargets = [...document.querySelectorAll('[data-pointer-parallax]')];

          window.addEventListener(
            'pointermove',
            (event) => {
              const x = (event.clientX / window.innerWidth - 0.5) * 18;
              const y = (event.clientY / window.innerHeight - 0.5) * 16;

              parallaxTargets.forEach((target) => {
                target.style.transform = `perspective(1200px) rotateY(${x * 0.55}deg) rotateX(${y * -0.45}deg) translate3d(${x * 0.6}px, ${y * 0.4}px, 0)`;
              });
            },
            { passive: true }
          );
        }

        const header = document.querySelector('[data-site-header]');
        const syncHeader = () => {
          if (!header) return;
          header.classList.toggle('is-scrolled', window.scrollY > 18);
        };

        syncHeader();
        window.addEventListener('scroll', syncHeader, { passive: true });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeMotion, { once: true });
      } else {
        initializeMotion();
      }
    </script>
  </body>
</html>
